<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="root" style="flex-grow: 1;">
        <ui:ProgressBar value="0" title="Усталость" name="fatigue" style="flex-shrink: 0; flex-grow: 0; width: 30%; margin-top: 8px; margin-right: 8px; margin-bottom: 8px; margin-left: 8px; font-size: 45%;" />
        <ui:VisualElement name="VisualElement" enabled="true" style="flex-grow: 1; flex-wrap: nowrap; justify-content: space-evenly; align-self: auto; flex-shrink: 1; align-content: auto; align-items: center;">
            <ui:Label text="Вы проиграли!&#10;Вы устали и пошли домой" name="gameover" style="font-size: 60%; visibility: visible; white-space: normal; -unity-text-align: upper-center; background-color: rgba(255, 255, 255, 0.53); -unity-font-style: normal; -unity-text-outline-width: 1px; -unity-text-outline-color: rgb(255, 0, 0);" />
            <ui:Label text="Строка для отображения помощи в управлении" name="helper" enabled="true" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="true" style="top: 0%; flex-shrink: 0; flex-grow: 0; flex-wrap: nowrap; flex-direction: column; align-self: auto; align-content: auto; justify-content: flex-start; align-items: auto; width: 50%; -unity-text-align: upper-center; background-image: none; background-color: rgba(255, 255, 255, 0.6); background-size: 100% 100%; background-position-x: center 0; -unity-background-scale-mode: stretch-to-fill; height: auto; font-size: 20%; text-overflow: clip; white-space: normal;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
